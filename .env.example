# Copy to .env for a private workstation or provide these values through your
# deployment platform. Never commit real secrets.

# Runtime: development | test | production
APP_ENV=development

# Required in production; use at least 32 random characters.
SESSION_SECRET=
TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Omit for the development-only in-memory repository. Production requires a
# PostgreSQL SQLAlchemy URL using the psycopg driver.
DATABASE_URL=

# placeholder: capacity-only local development
# recorded: reviewed fixture outputs + real optimizer
# openrouter: development-only semantic compiler + real optimizer
# openai: live semantic compiler + real optimizer (required in production)
ANALYSIS_ENGINE=placeholder
# Enables AI-assisted question and coverage drafting in every development
# analysis mode; it is also required when ANALYSIS_ENGINE=openai.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
OPENAI_REASONING_EFFORT=low

# OpenRouter is development-only. Its models are server-owned, not browser-selected.
OPENROUTER_API_KEY=
OPENROUTER_MODELS=google/gemini-2.5-flash-lite,qwen/qwen3.5-9b

# Standard process and local Compose settings.
PORT=8000
LOG_LEVEL=info
FORWARDED_ALLOW_IPS=127.0.0.1
POSTGRES_PASSWORD=
TEST_DATABASE_URL=
